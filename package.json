  "optionalDependencies": {
    "@swc/core-linux-x64-gnu": "1.15.4",
    "@swc/core-linux-x64-musl": "1.15.4"
  },
  "overrides": {
    "@apollo/server-plugin-landing-page-graphql-playground": {
      "@apollo/server": "5.2.0"
    }
  },
  "resolutions": {
    "@apollo/server": "5.2.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^@modules/(.*)$": "<rootDir>/modules/$1"
    }
  },
  "trustedDependencies": [
    "@apollo/protobufjs",
    "@nestjs/core",
    "@scarf/scarf",
    "@swc/core",
    "dtrace-provider"
  ]
