{
  "name": "project-name",
  "version": "0.0.1",
  "description": "",
  "author": "Minwan",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "nestjs": "bun --bun nest build -b swc && npx nodemon",
    "// ------------ NODEJS SCRIPTS ------------": "",
    "dev": "nest start --watch --env-file=.env.local",
    "webpack:dev": "node --env-file=.env.local -- nest build --webpack --webpackPath webpack-hmr.config.js --watch",
    "build": "nest build -b swc",
    "start": "nest start --env-file=.env.production",
    "start:prod": "node --env-file=.env.production dist/main.js",
    "start:debug": "nest start --debug --watch",
    "// ------------ TEST SCRIPTS ------------": "",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "// ------------ BUN SCRIPTS ------------": "",
    "bun:dev": "bun --bun --env-file=.env.local nest start --watch",
    "bun:build": "bun --bun nest build -b swc",
    "bun:start": "bun --bun --env-file=.env.production nest start",
    "bun:start:prod": "bun --env-file=.env.production dist/main.js",
    "bun:start:debug": "bun --bun nest start --debug --watch",
    "bun:test": "bun test",
    "bun:test:watch": "bun test --watch"
  },
  "dependencies": {
    "@as-integrations/express5": "1.1.2",
    "@keyv/redis": "5.1.6",
